# ============================================================
# /capcut 커맨드 환경 변수 — .env 로 복사해서 채우세요
# ============================================================

# (필수) ElevenLabs Scribe — Step 1 STT 기본 엔진
# https://elevenlabs.io/  →  API Keys
ELEVENLABS_API_KEY=

# (필수) Google Gemini — Step 3 B-roll 이미지 생성
# https://aistudio.google.com/  →  Get API key
GOOGLE_AI_API_KEY=

# ============================================================
# 경로 오버라이드 — 보통은 비워두면 자동 감지됩니다
# ============================================================

# 이 패키지의 프로젝트 루트 (share/capcut/) 를 자동 감지하지 못할 때만 명시
# 기본값: 각 .py 파일의 parents[2] 자동 계산
# CAPCUT_PROJECT_ROOT=

# FFmpeg/FFprobe 가 PATH 에 없을 때만 bin 디렉터리 절대경로 명시
# 기본값: PATH 에서 ffmpeg / ffprobe 직접 호출
# CAPCUT_FFMPEG_BIN=C:/ffmpeg/bin

# CapCut 드래프트 경로 — Windows 기본값 자동 감지됨
# 기본값: %LOCALAPPDATA%/CapCut/User Data/Projects/com.lveditor.draft
# CAPCUT_DRAFT_ROOT=
